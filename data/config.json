{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "qwen2.5:14b",
    "base_url": "http://localhost:11434/v1",
    "api_key_env": "LOCAL_LLM_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "enable_thinking": false,
    "enrichment_mode": "tiered",
    "enrichment_full_threshold": 8.0,
    "enrichment_brief_threshold": 7.0,
    "enrichment_max_full_items": 3,
    "enrichment_timeout_seconds": 120,
    "languages": [
      "zh",
      "en"
    ],
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true,
        "source_quality": "high",
        "source_weight": 0.5,
        "topics": ["ai", "developer-tools"],
        "priority": 10,
        "notes": "High-signal AI/developer account"
      },
      {
        "type": "repo_releases",
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": true,
        "source_quality": "high",
        "source_weight": 0.5,
        "topics": ["ai-infra", "llm-serving"],
        "priority": 10
      },
      {
        "type": "repo_releases",
        "owner": "sgl-project",
        "repo": "sglang",
        "enabled": true,
        "source_quality": "high",
        "source_weight": 0.5,
        "topics": ["ai-infra", "llm-serving"],
        "priority": 10
      },
      {
        "type": "repo_releases",
        "owner": "triton-lang",
        "repo": "triton",
        "enabled": true,
        "source_quality": "high",
        "source_weight": 0.5,
        "topics": ["ai-infra", "compilers"],
        "priority": 10
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 150,
      "source_quality": "high",
      "source_weight": 0.5,
      "topics": ["developer", "technology", "ai"],
      "priority": 8,
      "notes": "High-signal community discussion; broad topics may still need AI scoring"
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools",
        "source_quality": "high",
        "source_weight": 0.5,
        "topics": ["ai-tools", "developer"],
        "priority": 10
      },
      {
        "name": "OpenAI News",
        "url": "https://openai.com/news/rss.xml",
        "enabled": true,
        "category": "ai-lab",
        "source_quality": "high",
        "source_weight": 0.5,
        "topics": ["frontier-models", "ai-products"],
        "priority": 10
      },
      {
        "name": "Google DeepMind Blog",
        "url": "https://deepmind.google/blog/rss.xml",
        "enabled": true,
        "category": "ai-research",
        "source_quality": "high",
        "source_weight": 0.5,
        "topics": ["ai-research", "frontier-models"],
        "priority": 10
      },
      {
        "name": "Microsoft AI Blog",
        "url": "https://blogs.microsoft.com/ai/feed/",
        "enabled": true,
        "category": "enterprise-ai",
        "source_quality": "medium",
        "source_weight": 0.0,
        "topics": ["enterprise-ai", "ai-products", "developer"],
        "priority": 6,
        "notes": "Official Microsoft AI feed; useful for ecosystem coverage, but product/brand mix should not receive ranking boost"
      },
      {
        "name": "Hugging Face Blog",
        "url": "https://huggingface.co/blog/feed.xml",
        "enabled": true,
        "category": "ai-open-source",
        "source_quality": "high",
        "source_weight": 0.5,
        "topics": ["open-source-ai", "developer-tools"],
        "priority": 10
      },
      {
        "name": "GitHub Blog",
        "url": "https://github.blog/feed/",
        "enabled": true,
        "category": "developer-tools",
        "source_quality": "high",
        "source_weight": 0.5,
        "topics": ["developer-tools", "open-source"],
        "priority": 9
      },
      {
        "name": "GitHub Changelog",
        "url": "https://github.blog/changelog/feed/",
        "enabled": true,
        "category": "developer-tools",
        "source_quality": "high",
        "source_weight": 0.5,
        "topics": ["developer-tools", "github", "open-source"],
        "priority": 9,
        "notes": "Focused product and platform changes for developers"
      },
      {
        "name": "Latent Space",
        "url": "https://www.latent.space/feed",
        "enabled": true,
        "category": "ai-analysis",
        "source_quality": "high",
        "source_weight": 0.5,
        "topics": ["ai-infra", "frontier-models", "developer"],
        "priority": 9,
        "notes": "High-signal AI ecosystem analysis and AI infra coverage"
      },
      {
        "name": "Import AI",
        "url": "https://jack-clark.net/feed/",
        "enabled": true,
        "category": "ai-research",
        "source_quality": "high",
        "source_weight": 0.5,
        "topics": ["ai-research", "policy", "frontier-models"],
        "priority": 9,
        "notes": "Curated AI research and policy newsletter by Jack Clark"
      },
      {
        "name": "GitHub Trending - Daily",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "github-trending",
        "source_quality": "medium",
        "source_weight": 0.0,
        "topics": ["open-source", "developer-tools"],
        "priority": 5,
        "notes": "Useful discovery source, but broad and trend-driven"
      },
      {
        "name": "LWN.net",
        "url": "https://lwn.net/headlines/full_text?key=${LWN_KEY}",
        "enabled": false,
        "category": "linux-kernel"
      }
    ],
    "reddit": {
      "enabled": false,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60,
          "source_quality": "medium",
          "source_weight": 0.0,
          "topics": ["machine-learning", "research"],
          "priority": 4
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60,
          "source_quality": "medium",
          "source_weight": 0.0,
          "topics": ["local-llm", "open-source-ai"],
          "priority": 4
        }
      ],
      "users": [],
      "fetch_comments": 10
    },
    "telegram": {
      "enabled": true,
      "channels": [
        {
          "channel": "zaihuapd",
          "enabled": true,
          "fetch_limit": 20,
          "source_quality": "medium",
          "source_weight": 0.0,
          "topics": ["ai", "technology", "business"],
          "priority": 5,
          "notes": "Fast broad news source; AI score should remain the main filter"
        }
      ]
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24,
    "min_items_per_report": 10,
    "max_items_per_report": 15,
    "semantic_dedupe_candidate_limit": 25
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "last",
    "platform": "feishu",
    "layout": "collapsible",
    "fallback_layout": "markdown",
    "languages": [
      "zh"
    ],
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}
